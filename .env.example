# Copy to .env.local and fill in real values. Do NOT commit .env.local.
# In production these must also be set in the Vercel project
# (Project → Settings → Environment Variables, or `vercel env add <NAME> production`).

# Base URL of the SafeStorage report_analysis / agentic_crm backend.
NEXT_PUBLIC_API_BASE=https://safestorage.in/back

# Google Maps JS API key for the pickup-address Places autocomplete on the
# Create Quotation form. Falls back to the legacy CRM key if unset.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCse5f97FoDXrT5kKoeB1XGCxeCs12-mOE

# --- Resend fallback email (sent when a follow-up WhatsApp fails) ---
# Resend API key. A send-only (restricted) key is sufficient and recommended.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Long random string. The daily Vercel Cron and any manual call must send it as
# `Authorization: Bearer <CRON_SECRET>`. The fallback route fails closed if unset.
CRON_SECRET=replace-with-a-long-random-string

# Optional overrides (defaults shown). The From domain must be verified in Resend.
# FALLBACK_FROM_EMAIL=SafeStorage <followups@safestorage.in>
# FALLBACK_REPLY_TO=safestorage.in@gmail.com
